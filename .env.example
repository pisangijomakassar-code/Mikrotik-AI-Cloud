# === LLM Provider (OpenRouter) ===
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === MikroTik Routers ===
# Router credentials are now managed per-user via chat commands.
# See data/ directory for per-user router registries.

# === Telegram Bot ===
# Create bot via @BotFather on Telegram, get the token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Your numeric Telegram user ID (get from @userinfobot)
TELEGRAM_USER_ID=your-telegram-user-id

# === WhatsApp (optional) ===
# Requires WhatsApp Business API or waha.devlike.pro
# WHATSAPP_ENABLED=false
