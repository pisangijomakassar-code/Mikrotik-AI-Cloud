# === LLM Provider (OpenRouter) ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_USER_ID=your-telegram-user-id

# === Database (PostgreSQL) ===
DB_PASSWORD=change-me-strong-password

# === Dashboard ===
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
ADMIN_EMAIL=admin@mikrotik.local
ADMIN_PASSWORD=change-me-admin-password
VPS_HOST=103.67.244.215
# AUTH_URL must match the public URL users access the dashboard from (e.g. https://app.yourdomain.com)
# Wrong value causes 401 on all API calls from the browser.
AUTH_URL=http://localhost:3000
WEBHOOK_BASE_URL=

# === Agent ===
# Must match AGENT_TOKEN in the mikrotik-ai-agent stack .env
AGENT_TOKEN=

# ── Cloudflare Tunnel ──────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=           # Your Cloudflare account ID
CLOUDFLARE_API_TOKEN=            # API token with Tunnel:Edit + DNS:Edit permissions
CLOUDFLARE_TUNNEL_DOMAIN=        # e.g. tunnel.yourdomain.com
CLOUDFLARE_ZONE_ID=              # Zone ID for the tunnel domain

# ── SSTP VPN Server ────────────────────────────────────
SSTP_SERVER_HOST=                # VPS public IP or hostname
SSTP_VPN_SUBNET=10.10.0.0/24
SSTP_ADMIN_PASSWORD=             # SoftEther VPN admin password
