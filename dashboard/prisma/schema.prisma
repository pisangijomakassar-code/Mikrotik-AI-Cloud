generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TunnelMethod {
  CLOUDFLARE
  SSTP
  OVPN
  WIREGUARD
}

enum TunnelStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum ConnectionMethod {
  DIRECT
  TUNNEL
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  passwordHash  String?
  name          String
  telegramId    String     @unique
  botToken      String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  isProvisioned Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastActiveAt  DateTime?

  // Account lifecycle & notification preferences
  validUntil       DateTime?
  isLocked         Boolean   @default(false)
  notifAsOwner     Boolean   @default(true)
  notifAsReseller  Boolean   @default(true)

  routers                Router[]
  activityLogs           ActivityLog[]
  subscription           Subscription?
  tokenUsages            TokenUsage[]
  invoices               Invoice[]
  resellers              Reseller[]
  voucherBatches         VoucherBatch[]
  voucherProfileSettings VoucherProfileSetting[]
  voucherTypes           VoucherType[]
  trafficSnapshots       TrafficSnapshot[]
  resellerBotToken       String?

  @@index([telegramId])
  @@index([status])
}

model Router {
  id              String    @id @default(cuid())
  name            String
  host            String
  port            Int       @default(8728)
  username        String
  passwordEnc     String
  label           String    @default("")
  routerosVersion String    @default("")
  board           String    @default("")
  isDefault       Boolean   @default(false)
  addedAt         DateTime  @default(now())
  lastSeen        DateTime?
  connectionMethod ConnectionMethod @default(DIRECT)
  tunnel           Tunnel?

  // MikroTik DNS settings (for hotspot landing)
  dnsHotspot      String    @default("")

  // Hotspot branding (used when printing voucher cards)
  hotspotName     String    @default("")  // Display name di header voucher (kosong = pakai `name`)
  hotspotLogoUrl  String    @default("")  // URL/path logo (kosong = no logo)

  // Telegram bot integration (optional, for per-router notifications)
  telegramOwnerUsername String @default("")
  telegramOwnerId       String @default("")
  botToken              String @default("") // Fernet-encrypted when saved (same as password)
  botUsername           String @default("")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityLogs ActivityLog[]
  resellers    Reseller[]

  @@unique([userId, name])
  @@index([userId])
}

model Tunnel {
  id                    String       @id @default(cuid())
  method                TunnelMethod
  status                TunnelStatus @default(PENDING)

  // Cloudflare-specific
  cloudflareTunnelId    String?      @unique
  cloudflareTunnelToken String?      // encrypted, Fernet same as router passwords

  // SSTP-specific
  vpnUsername           String?
  vpnPassword           String?      // encrypted
  vpnAssignedIp         String?      // e.g. 10.10.0.5

  // WireGuard / OVPN shared fields
  winboxPort            Int?         // external port on VPS for Winbox forwarding (e.g. 18291)
  apiPort               Int?         // external port on VPS for MikroTik API (8728) forwarding
  subnetOctet           Int?         // customer /24 subnet index (10.8.X.0 or 10.9.X.0)
  routerOctet           Int?         // router IP within subnet (10.8.X.Y)
  wgClientPrivKey       String?      // WG client private key (Fernet encrypted)
  wgClientPubKey        String?      // WG client public key (for server peer config)
  wgServerPubKey        String?      // WG server public key (shown to user in script)

  // Common
  routerLanIp           String       @default("192.168.88.1")
  lastConnectedAt       DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  routerId String @unique
  router   Router @relation(fields: [routerId], references: [id], onDelete: Cascade)
  ports    TunnelPort[]

  @@index([status])
  @@index([method])
}

model TunnelPort {
  id          String  @id @default(cuid())
  serviceName String  // "api" | "winbox" | "ssh" | "webfig" | "api-ssl"
  remotePort  Int     // port on router: 8728, 8291, 22, 80, 8729
  localPort   Int?    // server-side proxy port (Cloudflare only, e.g. 19001)
  hostname    String? // CF tunnel hostname for this port (Cloudflare only)
  enabled     Boolean @default(true)

  tunnelId String
  tunnel   Tunnel @relation(fields: [tunnelId], references: [id], onDelete: Cascade)

  @@unique([tunnelId, serviceName])
  @@index([tunnelId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  action     String
  tool       String?
  status     String   @default("success")
  durationMs Int?
  details    String?
  errorMsg   String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  routerId String?
  router   Router? @relation(fields: [routerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([timestamp])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Billing Models (Phase 11) ──

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELED
}

model Subscription {
  id               String             @id @default(cuid())
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  tokenLimit       Int                @default(100)
  tokensUsed       Int                @default(0)
  billingCycleStart DateTime          @default(now())
  billingCycleEnd   DateTime?
  externalId       String?            @unique // Payment gateway subscription ID
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// LLM provider config — DB-backed override untuk env var. Singleton row (id="singleton").
// Kalau row ada → pakai ini; kalau tidak ada → fallback ke env OPENROUTER_API_KEY + model default.
model AppSettings {
  id          String   @id @default("singleton")
  llmProvider String   @default("openrouter")  // openrouter | openai | anthropic | google
  llmApiKey   String   @default("")            // Fernet-encrypted
  llmModel    String   @default("google/gemini-2.5-flash")
  updatedAt   DateTime @updatedAt
  updatedBy   String?                          // userId yang terakhir update (audit)
}

model TokenUsage {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  model       String   @default("")
  sessionId   String?
  durationMs  Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique @default(cuid())
  status      InvoiceStatus @default(DRAFT)
  amount      Int           @default(0)  // in cents
  currency    String        @default("IDR")
  periodStart DateTime
  periodEnd   DateTime
  tokensUsed  Int           @default(0)
  externalId  String?       @unique // Payment gateway invoice ID
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ── Reseller Models ──

enum ResellerStatus {
  ACTIVE
  INACTIVE
}

enum SaldoTransactionType {
  TOP_UP
  TOP_DOWN
  VOUCHER_PURCHASE
}

model Reseller {
  id           String         @id @default(cuid())
  name         String
  phone        String         @default("")
  telegramId   String         @default("")
  balance      Int            @default(0)
  discount     Int            @default(0)   // Diskon (%)
  voucherGroup String         @default("default") // Grup Voucher
  uplink       String         @default("")  // ID upline reseller (opsional)
  status       ResellerStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  routerId String
  router   Router @relation(fields: [routerId], references: [id], onDelete: Cascade)

  transactions   SaldoTransaction[]
  voucherBatches VoucherBatch[]

  @@unique([routerId, name])  // nama reseller unik per router
  @@index([userId])
  @@index([routerId])
  @@index([telegramId])
}

model SaldoTransaction {
  id              String               @id @default(cuid())
  type            SaldoTransactionType
  amount          Int
  balanceBefore   Int
  balanceAfter    Int
  description     String               @default("")
  // Voucher purchase details (for history table)
  hargaVoucher    Int                  @default(0)
  voucherUsername String               @default("")
  voucherPassword String               @default("")
  voucherInfo     String               @default("") // e.g. profile name / package
  proofImageUrl   String               @default("") // URL bukti transfer/deposit
  createdAt       DateTime             @default(now())

  resellerId String
  reseller   Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([createdAt])
}

model VoucherProfileSetting {
  id          String   @id @default(cuid())
  profileName String
  price       Int      @default(0)
  charType    String   @default("alphanumeric")
  charLength  Int      @default(6)
  loginType   String   @default("separate")
  limitUptime String?
  limitQuota  String?
  qrColor     String   @default("#000000")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, profileName])
  @@index([userId])
}

model VoucherType {
  id               String   @id @default(cuid())
  namaVoucher      String
  deskripsi        String   @default("")
  harga            Int      @default(0)
  markUp           Int      @default(0)
  server           String   @default("all")
  profile          String   @default("")
  limitUptime      String   @default("0")
  limitQuotaDl     Int      @default(0)
  limitQuotaUl     Int      @default(0)
  limitQuotaTotal  Int      @default(0)
  typeChar         String   @default("Random abcd")
  typeLogin        String   @default("Username & Password")
  prefix           String   @default("")
  panjangKarakter  Int      @default(6)
  voucherGroup     String   @default("default") // comma-separated: "default,1,2"
  voucherColor     String   @default("#ffffff")
  addressPool      String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VoucherBatch {
  id           String   @id @default(cuid())
  routerName   String
  profile      String
  count        Int
  pricePerUnit Int      @default(0)
  totalCost    Int
  vouchers     Json
  source       String   @default("dashboard")
  createdAt    DateTime @default(now())

  discount     Int      @default(0)
  markUp       Int      @default(0)
  hargaEndUser Int      @default(0)

  resellerId String?
  reseller   Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([userId])
  @@index([createdAt])
}


model TrafficSnapshot {
  // Snapshot counter /interface dari RouterOS — di-poll cron tiap 10 menit.
  // Untuk hitung delta antar snapshot → monthly bandwidth usage.
  // Reboot detection: kalau current < previous → counter reset; pakai current
  // sebagai base baru.
  // Retention 12 bulan rolling — auto-cleanup mingguan.
  id          String   @id @default(cuid())
  routerName  String
  interfaceName String
  txBytes     BigInt
  rxBytes     BigInt
  takenAt     DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, routerName, interfaceName, takenAt])
  @@index([userId, routerName, takenAt])
  @@index([takenAt])
}
