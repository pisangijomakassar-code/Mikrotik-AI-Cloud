generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TunnelMethod {
  CLOUDFLARE
  SSTP
}

enum TunnelStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum ConnectionMethod {
  DIRECT
  TUNNEL
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  passwordHash  String?
  name          String
  telegramId    String     @unique
  botToken      String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  isProvisioned Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastActiveAt  DateTime?

  routers          Router[]
  activityLogs     ActivityLog[]
  subscription     Subscription?
  tokenUsages      TokenUsage[]
  invoices         Invoice[]
  resellers        Reseller[]
  voucherBatches   VoucherBatch[]
  resellerBotToken String?

  @@index([telegramId])
  @@index([status])
}

model Router {
  id              String    @id @default(cuid())
  name            String
  host            String
  port            Int       @default(8728)
  username        String
  passwordEnc     String
  label           String    @default("")
  routerosVersion String    @default("")
  board           String    @default("")
  isDefault       Boolean   @default(false)
  addedAt         DateTime  @default(now())
  lastSeen        DateTime?
  connectionMethod ConnectionMethod @default(DIRECT)
  tunnel           Tunnel?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityLogs ActivityLog[]

  @@unique([userId, name])
  @@index([userId])
}

model Tunnel {
  id                    String       @id @default(cuid())
  method                TunnelMethod
  status                TunnelStatus @default(PENDING)

  // Cloudflare-specific
  cloudflareTunnelId    String?      @unique
  cloudflareTunnelToken String?      // encrypted, Fernet same as router passwords

  // SSTP-specific
  vpnUsername           String?
  vpnPassword           String?      // encrypted
  vpnAssignedIp         String?      // e.g. 10.10.0.5

  // Common
  routerLanIp           String       @default("192.168.88.1")
  lastConnectedAt       DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  routerId String @unique
  router   Router @relation(fields: [routerId], references: [id], onDelete: Cascade)
  ports    TunnelPort[]

  @@index([status])
  @@index([method])
}

model TunnelPort {
  id          String  @id @default(cuid())
  serviceName String  // "api" | "winbox" | "ssh" | "webfig" | "api-ssl"
  remotePort  Int     // port on router: 8728, 8291, 22, 80, 8729
  localPort   Int?    // server-side proxy port (Cloudflare only, e.g. 19001)
  hostname    String? // CF tunnel hostname for this port (Cloudflare only)
  enabled     Boolean @default(true)

  tunnelId String
  tunnel   Tunnel @relation(fields: [tunnelId], references: [id], onDelete: Cascade)

  @@unique([tunnelId, serviceName])
  @@index([tunnelId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  action     String
  tool       String?
  status     String   @default("success")
  durationMs Int?
  details    String?
  errorMsg   String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  routerId String?
  router   Router? @relation(fields: [routerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([timestamp])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Billing Models (Phase 11) ──

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELED
}

model Subscription {
  id               String             @id @default(cuid())
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  tokenLimit       Int                @default(20000)
  tokensUsed       Int                @default(0)
  billingCycleStart DateTime          @default(now())
  billingCycleEnd   DateTime?
  externalId       String?            @unique // Payment gateway subscription ID
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TokenUsage {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  model       String   @default("")
  sessionId   String?
  durationMs  Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique @default(cuid())
  status      InvoiceStatus @default(DRAFT)
  amount      Int           @default(0)  // in cents
  currency    String        @default("IDR")
  periodStart DateTime
  periodEnd   DateTime
  tokensUsed  Int           @default(0)
  externalId  String?       @unique // Payment gateway invoice ID
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ── Reseller Models ──

enum ResellerStatus {
  ACTIVE
  INACTIVE
}

enum SaldoTransactionType {
  TOP_UP
  TOP_DOWN
  VOUCHER_PURCHASE
}

model Reseller {
  id         String         @id @default(cuid())
  name       String
  phone      String         @default("")
  telegramId String         @default("")
  balance    Int            @default(0)
  status     ResellerStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions   SaldoTransaction[]
  voucherBatches VoucherBatch[]

  @@index([userId])
  @@index([telegramId])
}

model SaldoTransaction {
  id            String               @id @default(cuid())
  type          SaldoTransactionType
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  description   String               @default("")
  createdAt     DateTime             @default(now())

  resellerId String
  reseller   Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([createdAt])
}

model VoucherBatch {
  id           String   @id @default(cuid())
  routerName   String
  profile      String
  count        Int
  pricePerUnit Int      @default(0)
  totalCost    Int
  vouchers     Json
  source       String   @default("dashboard")
  createdAt    DateTime @default(now())

  resellerId String?
  reseller   Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([userId])
  @@index([createdAt])
}

