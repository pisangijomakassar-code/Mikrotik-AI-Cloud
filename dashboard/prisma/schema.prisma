generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  passwordHash  String?
  name          String
  telegramId    String     @unique
  botToken      String?
  agentUrl      String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  isProvisioned Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastActiveAt  DateTime?

  routers      Router[]
  activityLogs ActivityLog[]
  subscription Subscription?
  tokenUsages  TokenUsage[]
  invoices     Invoice[]

  @@index([telegramId])
  @@index([status])
}

model Router {
  id              String    @id @default(cuid())
  name            String
  host            String
  port            Int       @default(8728)
  username        String
  passwordEnc     String
  label           String    @default("")
  routerosVersion String    @default("")
  board           String    @default("")
  isDefault       Boolean   @default(false)
  addedAt         DateTime  @default(now())
  lastSeen        DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityLogs ActivityLog[]

  @@unique([userId, name])
  @@index([userId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  action     String
  tool       String?
  status     String   @default("success")
  durationMs Int?
  details    String?
  errorMsg   String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  routerId String?
  router   Router? @relation(fields: [routerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([timestamp])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Billing Models (Phase 11) ──

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELED
}

model Subscription {
  id               String             @id @default(cuid())
  plan             SubscriptionPlan   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  tokenLimit       Int                @default(20000)
  tokensUsed       Int                @default(0)
  billingCycleStart DateTime          @default(now())
  billingCycleEnd   DateTime?
  externalId       String?            @unique // Payment gateway subscription ID
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TokenUsage {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  model       String   @default("")
  sessionId   String?
  durationMs  Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique @default(cuid())
  status      InvoiceStatus @default(DRAFT)
  amount      Int           @default(0)  // in cents
  currency    String        @default("IDR")
  periodStart DateTime
  periodEnd   DateTime
  tokensUsed  Int           @default(0)
  externalId  String?       @unique // Payment gateway invoice ID
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
